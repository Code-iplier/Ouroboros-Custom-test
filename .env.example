# API Configuration — ouroboros-ai
# Copy to .env.local and update values

# Backend API Base URL (Orchestrator service)
VITE_API_BASE_URL=http://localhost:8000

# API Version (optional, defaults to v1)
VITE_API_VERSION=v1

# API request timeout in milliseconds (default: 120000)
VITE_API_TIMEOUT=60000

# App Version (set automatically by CI from git tag)
# VITE_APP_VERSION=

# Demo/Mock Mode — set to "true" to use MSW (Mock Service Worker)
# to simulate the backend API without a running server
VITE_USE_MOCK_API=true
